def list_patient_ids_from_dir() -> List[str]:
    """スライスディレクトリ内の患者IDフォルダをソートして返す"""
    base = Path(SLICES_BASE_DIR)
    if not base.exists():
        raise FileNotFoundError(f"スライスディレクトリが見つかりません: {base}")
    ids = sorted(
        d.name for d in base.iterdir()
        if d.is_dir() and any(d.glob("*.jpg"))
    )
    return ids


def _get_font(size: int):
    """ラベル用フォントを取得（システムフォントにフォールバック）"""
    for name in ("arial.ttf", "Arial.ttf", "DejaVuSans.ttf"):
        try:
            return ImageFont.truetype(name, size)
        except OSError:
            continue
    return ImageFont.load_default()


def build_grid_image(patient_id: str) -> Optional[bytes]:
    """
    患者IDフォルダ内のバラ画像を読み込み、
    5×5グリッド（スライス番号ラベル付き）のJPEGバイトを返す。
    """
    folder = Path(SLICES_BASE_DIR) / patient_id
    if not folder.exists():
        print(f"⚠️  {patient_id}: フォルダがありません ({folder})", file=sys.stderr)
        return None

    # スライス番号順にソート
    slice_files = sorted(
        folder.glob("*.jpg"),
        key=lambda p: int(p.stem) if p.stem.isdigit() else 0,
    )
    if not slice_files:
        print(f"⚠️  {patient_id}: スライス画像がありません", file=sys.stderr)
        return None

    # 1枚目からセルサイズを決定
    sample = Image.open(slice_files[0])
    cell_w, cell_h = sample.size
    sample.close()

    total_slots = GRID_COLS * GRID_ROWS
    font = _get_font(max(12, LABEL_HEIGHT - 4))

    grid_w = cell_w * GRID_COLS
    grid_h = (cell_h + LABEL_HEIGHT) * GRID_ROWS
    grid_img = Image.new("RGB", (grid_w, grid_h), color=(0, 0, 0))
    draw = ImageDraw.Draw(grid_img)

    for idx, fpath in enumerate(slice_files[:total_slots]):
        row, col = divmod(idx, GRID_COLS)
        x = col * cell_w
        y = row * (cell_h + LABEL_HEIGHT)

        # スライス番号ラベル（白背景＋黒文字）
        label = f"Slice {fpath.stem}"
        draw.rectangle([x, y, x + cell_w, y + LABEL_HEIGHT], fill=(255, 255, 255))
        draw.text((x + 4, y + 1), label, fill=(0, 0, 0), font=font)

        # スライス画像を貼り付け
        img = Image.open(fpath).convert("RGB").resize((cell_w, cell_h))
        grid_img.paste(img, (x, y + LABEL_HEIGHT))
        img.close()

    buf = io.BytesIO()
    grid_img.save(buf, format="JPEG", quality=GRID_JPEG_QUALITY)
    return buf.getvalue()


def grid_to_data_url(grid_bytes: bytes) -> str:
    return f"data:image/jpeg;base64,{base64.b64encode(grid_bytes).decode('ascii')}"

