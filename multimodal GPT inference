def parse_probabilities(text: str) -> Dict[str, Optional[float]]:
    """
    GPT出力の [PROBABILITIES] ブロック内のJSONから確率値を抽出する。
    パース失敗時は None を返す。
    """
    result: Dict[str, Optional[float]] = {
        "prob_mrs_ge3": None,
        "prob_mrs_ge4": None,
        "prob_mrs_ge5": None,
        "prob_mrs_eq6": None,
    }
    block = re.search(r"\[PROBABILITIES\](.*?)\[/PROBABILITIES\]", text, re.DOTALL)
    if not block:
        return result
    # コードフェンス(```json ... ```)があれば除去してJSONだけ取り出す
    body = re.sub(r"```(?:json)?", "", block.group(1)).replace("```", "").strip()
    try:
        data = json.loads(body)
        mapping = {
            "prob_mrs_ge3": "mRS_ge3",
            "prob_mrs_ge4": "mRS_ge4",
            "prob_mrs_ge5": "mRS_ge5",
            "prob_mrs_eq6": "mRS_eq6",
        }
        for key, json_key in mapping.items():
            if json_key in data:
                result[key] = round(float(data[json_key]), 4)
    except (json.JSONDecodeError, ValueError):
        pass
    return result

def parse_ct_findings(text: str) -> str:
    block = re.search(r"\[CT_FINDINGS\](.*?)\[/CT_FINDINGS\]", text, re.DOTALL)
    return block.group(1).strip() if block else ""

def parse_severity(text: str) -> str:
    block = re.search(r"\[SEVERITY\](.*?)\[/SEVERITY\]", text, re.DOTALL)
    return block.group(1).strip() if block else ""

def parse_predicted_mrs(text: str) -> Optional[int]:
    """[PREDICTED_MRS]タグから退院時mRS推定値（0–6の整数）を抽出する。"""
    block = re.search(r"\[PREDICTED_MRS\](.*?)\[/PREDICTED_MRS\]", text, re.DOTALL)
    if not block:
        return None
    try:
        val = int(block.group(1).strip())
        if 0 <= val <= 6:
            return val
    except ValueError:
        pass
    return None

def parse_reasoning(text: str) -> str:
    block = re.search(r"\[REASONING\](.*?)\[/REASONING\]", text, re.DOTALL)
    return block.group(1).strip() if block else ""

_REFUSAL_PATTERN = re.compile(
    r"I(?:'m| am) sorry|cannot assist|can't assist|unable to (help|assist|process)|"
    r"I apologize|not able to (help|assist)",
    re.IGNORECASE,
)

def _is_refusal(text: str) -> bool:
    """コンテンツフィルタ / モデル拒否レスポンスを検出する"""
    return bool(_REFUSAL_PATTERN.search(text)) or "[PROBABILITIES]" not in text

def _build_fallback_content(grid_data_url: str) -> List[Dict]:
    """
    拒否発生時のフォールバックプロンプト。
    確率推定部を最小限に抑え、専門用語を統計的表現に置き換える。
    """
    prompt = """\
## Head CT — ICH Functional Outcome Estimation

5×5 grid of non-contrast CT slices (labeled with slice numbers), 5 mm thick.

### Task
1. Describe hematoma location, estimated volume (ABC/2), IVH, mass effect.
2. Rate overall severity: low / moderate / high / very high.
3. Estimate discharge functional outcome probabilities (mRS scale, 0=independent, 6=worst):

[PROBABILITIES]
```json
{{
  "mRS_ge3": <0.00-1.00>,
  "mRS_ge4": <0.00-1.00>,
  "mRS_ge5": <0.00-1.00>,
  "mRS_eq6": <0.00-1.00>
}}
```
[/PROBABILITIES]

[CT_FINDINGS]<findings>[/CT_FINDINGS]
[SEVERITY]<category>[/SEVERITY]
[REASONING]<2-3 sentences>[/REASONING]
"""
    return [
        {"type": "input_text",  "text": prompt},
        {"type": "input_image", "image_url": grid_data_url},
    ]

def responses_once(user_content: List[Dict]) -> Tuple[str, Optional[str], str]:
    system_instructions = (
        "You are a radiologist and neurologist reviewing non-contrast head CT images "
        "for a retrospective clinical research study on intracerebral hemorrhage outcomes. "
        "The CT image is a 5×5 grid of labeled slices — use the slice numbers to reference specific slices. "
        "Provide structured imaging analysis and statistical probability estimates "
        "for functional outcome at hospital discharge using the modified Rankin Scale. "
        "Follow the output format exactly. "
        "All reasoning must appear only inside the designated tags. "
        "Do NOT produce free text outside the tags."
    )
    for attempt in range(1, MAX_RETRIES + 1):
        try:
            kwargs = dict(
                model=deployment,
                instructions=system_instructions,
                input=[{"role": "user", "content": user_content}],
                text={"verbosity": "low"},
            )
            if STRICT_REASONING:
                kwargs["reasoning"] = {"effort": REASONING_EFFORT}
            resp = client.responses.create(**kwargs)
            text = _extract_text_from_response(resp)
            used_model = _extract_model_from_response(resp)
            # 拒否 / 不完全レスポンスを検出してフォールバック content で即リトライ
            if text and _is_refusal(text) and isinstance(user_content[0].get("text", ""), str):
                if "fallback" not in user_content[0].get("text", ""):
                    fb_image = next(
                        (c["image_url"] for c in user_content if c.get("type") == "input_image"),
                        None,
                    )
                    if fb_image:
                        fb_content = _build_fallback_content(fb_image)
                        fb_content[0]["text"] = "fallback\n" + fb_content[0]["text"]
                        user_content = fb_content
                        print("   ⚠️  Refusal detected — retrying with fallback prompt",
                              file=sys.stderr)
                        continue
            return (text if text else FALLBACK_TEXT, None, used_model)
        except RETRY_ERRORS as exc:
            msg = str(exc)
            if "not supported" in msg.lower() or "unknown parameter" in msg.lower():
                return (FALLBACK_TEXT,
                        f"request failed (reasoning/verbosity unsupported): {msg}",
                        str(deployment))
            if attempt == MAX_RETRIES:
                return (FALLBACK_TEXT, f"request failed after retries: {msg}", str(deployment))
            # 429 / no_capacity は長い指数バックオフ
            is_rate_limit = (
                "429" in msg or "no_capacity" in msg.lower()
                or "too_many_requests" in msg.lower() or "rate limit" in msg.lower()
            )
            if is_rate_limit:
                wait = RATE_LIMIT_WAIT_SEC * (2 ** (attempt - 1))  # 60, 120, 240, ...
                print(f"   ⚠️ 429/no_capacity (attempt {attempt}/{MAX_RETRIES}): "
                      f"{wait}秒待機してリトライします…", file=sys.stderr)
            else:
                wait = WAIT_SEC * attempt
            time.sleep(wait)
        except Exception as exc:
            return (FALLBACK_TEXT, f"unexpected error: {exc}", str(deployment))

# ───────────────── 保存 ───────────────── #

def save_results(results: List[Dict], xlsx_path: Path, csv_path: Path) -> None:
    if not results:
        print("⚠️ 保存対象が空のためスキップ", file=sys.stderr)
        return
    df = pd.DataFrame(results)
    with pd.ExcelWriter(xlsx_path, engine="xlsxwriter") as w:
        df.to_excel(w, index=False, sheet_name="results")
    print(f"✅ Results saved (xlsx): {xlsx_path}")
    df.to_csv(csv_path, index=False, encoding="utf-8-sig", quoting=csv.QUOTE_ALL)
    print(f"✅ Results saved (csv):  {csv_path}")

# ─────────────────── メイン ─────────────────── #

def run_inference_for_dataset(
    imp_idx: int,
    patient_df: Optional[pd.DataFrame],
    folder_names: List[str],
) -> List[Dict]:
    """
    1つの補完データセット（imp_idx: 1〜N_IMPUTATIONS）に対して
    全患者フォルダを推論し、結果リストを返す。
    """
    results: List[Dict] = []
    for i, folder in enumerate(folder_names, 1):
        # フォルダ名から患者IDとCT撮影日を解析
        pid_str, ct_date = parse_folder_name(folder)

        # Excelから該当行を取得し、臨床データを整形
        patient_row   = find_patient_row(patient_df, pid_str, ct_date)
        clinical_data = format_clinical_data(patient_row)

        if patient_row is not None:
            matched_label = (
                f"入院日={patient_row['_入院日'].date() if pd.notna(patient_row['_入院日']) else 'N/A'}"
            )
            print(f"   📋 Excel matched: 患者番号={pid_str}  {matched_label}")
        else:
            print(f"   ⚠️  Excel unmatched: folder={folder}", file=sys.stderr)

        grid_bytes = build_grid_image(folder)

        if grid_bytes is None:
            print(f"⚠️  [{i}/{len(folder_names)}] {folder}: 画像なし → スキップ", file=sys.stderr)
            results.append({
                "imputation_index": imp_idx,
                "folder": folder, "patient_id": pid_str,
                "ct_date": ct_date.strftime("%Y-%m-%d") if ct_date else "",
                "excel_matched": patient_row is not None,
                "ct_findings": "", "severity": "", "reasoning": "",
                "prob_mrs_ge3": None, "prob_mrs_ge4": None,
                "prob_mrs_ge5": None, "prob_mrs_eq6": None,
                "predicted_mrs": None,
                "raw_response": "SKIPPED (no slice images found)",
                "model_used": str(deployment),
                "reasoning_effort": REASONING_EFFORT, "error": ""
            })
            continue

        grid_url     = grid_to_data_url(grid_bytes)
        user_content = build_user_content(grid_url, clinical_data)
        print(f"[imp{imp_idx}][{i}/{len(folder_names)}] querying… folder={folder}"
              f"  clinical={'yes' if clinical_data else 'no'}")

        # 確率が4つ全て揃うまでリトライ（欠損なし保証）
        _PROB_KEYS = ("prob_mrs_ge3", "prob_mrs_ge4", "prob_mrs_ge5", "prob_mrs_eq6")
        ans, err, used_model = FALLBACK_TEXT, "", str(deployment)
        probs: Dict[str, Optional[float]] = {k: None for k in _PROB_KEYS}
        for _prob_attempt in range(1, MAX_PROB_RETRIES + 1):
            ans, err, used_model = responses_once(user_content)
            probs = parse_probabilities(ans)
            if all(probs[k] is not None for k in _PROB_KEYS):
                break
            missing = [k for k in _PROB_KEYS if probs[k] is None]
            print(f"   ⚠️ 確率欠損 (attempt {_prob_attempt}/{MAX_PROB_RETRIES})"
                  f"  missing={missing} → リトライ", file=sys.stderr)
            time.sleep(WAIT_SEC)
        else:
            print(f"   ❌ {folder}: {MAX_PROB_RETRIES}回リトライ後も確率欠損。最終値で保存します。",
                  file=sys.stderr)

        print(f"   ↳ model: {used_model}")

        ct_findings   = parse_ct_findings(ans)
        severity      = parse_severity(ans)
        predicted_mrs = parse_predicted_mrs(ans)
        reasoning     = parse_reasoning(ans)

        results.append({
            "imputation_index": imp_idx,
            "folder":         folder,
            "patient_id":     pid_str,
            "ct_date":        ct_date.strftime("%Y-%m-%d") if ct_date else "",
            "excel_matched":  patient_row is not None,
            "ct_findings":    ct_findings,
            "severity":       severity,
            "prob_mrs_ge3":   probs["prob_mrs_ge3"],
            "prob_mrs_ge4":   probs["prob_mrs_ge4"],
            "prob_mrs_ge5":   probs["prob_mrs_ge5"],
            "prob_mrs_eq6":   probs["prob_mrs_eq6"],
            "predicted_mrs":  predicted_mrs,
            "reasoning":      reasoning,
            "raw_response":   ans,
            "model_used":     used_model,
            "reasoning_effort": REASONING_EFFORT,
            "error":          err or ""
        })
    return results


def main() -> None:
    folder_names = list_patient_ids_from_dir()

    print(f"🤖 Model (Azure deployment): {deployment}")
    print(f"🌐 Endpoint: {endpoint}")
    print(f"🖼  Image source: {SLICES_BASE_DIR}")
    print(f"👥 Folders found: {len(folder_names)}")
    print(f"🔁 Imputation sets: {N_IMPUTATIONS}")

    for imp_idx in range(1, N_IMPUTATIONS + 1):
        # ─── 補完データセットのパスを解決 ───────────────────────────── #
        imp_path = DESKTOP_DIR / f"{IMPUTED_DATA_PREFIX}{imp_idx}.xlsx"
        print(f"\n{'='*60}")
        print(f"📂 Imputation {imp_idx}/{N_IMPUTATIONS}: {imp_path}")
        print(f"{'='*60}")

        patient_df = load_patient_data(str(imp_path))

        # ─── 推論実行 ────────────────────────────────────────────────── #
        results: List[Dict] = []
        try:
            results = run_inference_for_dataset(imp_idx, patient_df, folder_names)
        finally:
            # imputation ごとに独立したファイルへ保存
            out_xlsx = DESKTOP_DIR / f"{OUTPUT_FILE_PREFIX}{imp_idx}.xlsx"
            out_csv  = DESKTOP_DIR / f"{OUTPUT_FILE_PREFIX}{imp_idx}.csv"
            print(f"💾 Saving imp{imp_idx} → {out_xlsx}")
            save_results(results, out_xlsx, out_csv)

    print("\n🎉 All done!  ich_mrs_results_imp1〜5.xlsx/csv を保存しました。")

if __name__ == "__main__":
    main()
