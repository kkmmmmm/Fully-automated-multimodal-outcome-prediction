def load_patient_data(path_override: Optional[str] = None) -> Optional[pd.DataFrame]:
    """
    patients data Excel を読み込み、列名を正規化して返す。
    - A列: 患者番号（整数）→ id7（7桁ゼロパディング文字列）を追加
    - B列: 入院日（datetime）
    - C列: 退院日（datetime）
    - D列以降: 臨床データ
    path_override が指定された場合はそちらを優先（多重補完データセット用）。
    ファイルが存在しない場合は None を返し警告を表示。
    """
    path = Path(path_override) if path_override else Path(PATIENTS_DATA_PATH)
    if not path.exists():
        # DESKTOP_DIR 直下も試す（同じデスクトップに置いた場合）
        fallback = DESKTOP_DIR / "patients data.xlsx"
        if fallback.exists():
            path = fallback
        else:
            print(f"⚠️ patients data ファイルが見つかりません: {path}\n"
                  "   臨床データなしで画像のみで推論します。", file=sys.stderr)
            return None
    try:
        df = pd.read_excel(path, header=0)
        # A/B/C列を固定名で参照できるよう内部列名を付ける
        cols = list(df.columns)
        df.rename(columns={
            cols[0]: "_患者番号",
            cols[1]: "_入院日",
            cols[2]: "_退院日",
        }, inplace=True)
        df["_患者番号"] = pd.to_numeric(df["_患者番号"], errors="coerce")
        df["_入院日"]   = pd.to_datetime(df["_入院日"],   errors="coerce")
        df["_退院日"]   = pd.to_datetime(df["_退院日"],   errors="coerce")
        # 7桁ゼロパディングIDを事前計算
        df["_id7"] = df["_患者番号"].apply(
            lambda x: str(int(x)).zfill(7) if pd.notna(x) else ""
        )
        print(f"📋 {path.name} 読み込み完了: {len(df)} 行, {len(df.columns)} 列")
        return df
    except Exception as e:
        print(f"⚠️ {path.name} の読み込みに失敗しました: {e}\n"
              "   臨床データなしで画像のみで推論します。", file=sys.stderr)
        return None


def parse_folder_name(folder_name: str) -> Tuple[str, Optional[datetime]]:
    """
    フォルダ名から（7桁ゼロパディング患者ID, CT撮影日）を返す。
    - 単回入院: "0038605"       → ("0038605", None)
    - 複数入院: "1970525_20240918" → ("1970525", datetime(2024,9,18))
    桁数が7未満の場合は左ゼロ埋めする。
    """
    m = re.fullmatch(r"(\d+)(?:_(\d{8}))?", folder_name)
    if not m:
        return folder_name, None
    pid_str  = m.group(1).zfill(7)
    date_str = m.group(2)
    ct_date  = datetime.strptime(date_str, "%Y%m%d") if date_str else None
    return pid_str, ct_date


def find_patient_row(
    patient_df: Optional[pd.DataFrame],
    pid_str: str,
    ct_date: Optional[datetime],
) -> Optional[pd.Series]:
    """
    patients data.xlsx の中から該当行を1行返す。
    - ct_date が None（単回入院）: 患者番号が一致する行
    - ct_date あり（複数入院）  : 患者番号が一致し、入院日 ≦ ct_date ≦ 退院日 となる行
    複数ヒットした場合は先頭行を使用。見つからない場合は None。
    """
    if patient_df is None:
        return None
    matched = patient_df[patient_df["_id7"] == pid_str]
    if matched.empty:
        return None
    if ct_date is None:
        return matched.iloc[0]
    # 入院日〜退院日の範囲内にCT撮影日が含まれる行を探す
    ct_ts = pd.Timestamp(ct_date)
    in_range = matched[
        (matched["_入院日"].notna()) & (matched["_退院日"].notna()) &
        (matched["_入院日"] <= ct_ts) & (ct_ts <= matched["_退院日"])
    ]
    if not in_range.empty:
        return in_range.iloc[0]
    # 範囲ヒットなし → 日付が最も近い行にフォールバック
    diffs = (matched["_入院日"] - ct_ts).abs()
    return matched.loc[diffs.idxmin()]


def format_clinical_data(row: Optional[pd.Series]) -> str:
    """
    患者の臨床データ（D列以降）をプロンプト用Markdownテーブルに整形する。
    内部管理列（_で始まる列）は除外する。
    """
    if row is None:
        return ""
    lines = ["| Variable | Value |", "|----------|-------|"]
    for col, val in row.items():
        col_str = str(col)
        if col_str.startswith("_"):
            continue
        val_str = "" if pd.isna(val) else str(val)
        lines.append(f"| {col_str} | {val_str} |")
    return "\n".join(lines)


