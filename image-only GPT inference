# ───────────────── スライス画像読み込み・グリッド合成 ───────────────── #

def list_patient_ids_from_dir() -> List[str]:
    """スライスディレクトリ内の患者IDフォルダをソートして返す"""
    base = Path(SLICES_BASE_DIR)
    if not base.exists():
        raise FileNotFoundError(f"スライスディレクトリが見つかりません: {base}")
    ids = sorted(
        d.name for d in base.iterdir()
        if d.is_dir() and any(d.glob("*.jpg"))
    )
    return ids


def _get_font(size: int):
    """ラベル用フォントを取得（システムフォントにフォールバック）"""
    for name in ("arial.ttf", "Arial.ttf", "DejaVuSans.ttf"):
        try:
            return ImageFont.truetype(name, size)
        except OSError:
            continue
    return ImageFont.load_default()


def build_grid_image(patient_id: str) -> Optional[bytes]:
    """
    患者IDフォルダ内のバラ画像を読み込み、
    5×5グリッド（スライス番号ラベル付き）のJPEGバイトを返す。
    """
    folder = Path(SLICES_BASE_DIR) / patient_id
    if not folder.exists():
        print(f"⚠️  {patient_id}: フォルダがありません ({folder})", file=sys.stderr)
        return None

    # スライス番号順にソート
    slice_files = sorted(
        folder.glob("*.jpg"),
        key=lambda p: int(p.stem) if p.stem.isdigit() else 0,
    )
    if not slice_files:
        print(f"⚠️  {patient_id}: スライス画像がありません", file=sys.stderr)
        return None

    # 1枚目からセルサイズを決定
    sample = Image.open(slice_files[0])
    cell_w, cell_h = sample.size
    sample.close()

    total_slots = GRID_COLS * GRID_ROWS
    font = _get_font(max(12, LABEL_HEIGHT - 4))

    grid_w = cell_w * GRID_COLS
    grid_h = (cell_h + LABEL_HEIGHT) * GRID_ROWS
    grid_img = Image.new("RGB", (grid_w, grid_h), color=(0, 0, 0))
    draw = ImageDraw.Draw(grid_img)

    for idx, fpath in enumerate(slice_files[:total_slots]):
        row, col = divmod(idx, GRID_COLS)
        x = col * cell_w
        y = row * (cell_h + LABEL_HEIGHT)

        # スライス番号ラベル（白背景＋黒文字）
        label = f"Slice {fpath.stem}"
        draw.rectangle([x, y, x + cell_w, y + LABEL_HEIGHT], fill=(255, 255, 255))
        draw.text((x + 4, y + 1), label, fill=(0, 0, 0), font=font)

        # スライス画像を貼り付け
        img = Image.open(fpath).convert("RGB").resize((cell_w, cell_h))
        grid_img.paste(img, (x, y + LABEL_HEIGHT))
        img.close()

    buf = io.BytesIO()
    grid_img.save(buf, format="JPEG", quality=GRID_JPEG_QUALITY)
    return buf.getvalue()


def grid_to_data_url(grid_bytes: bytes) -> str:
    return f"data:image/jpeg;base64,{base64.b64encode(grid_bytes).decode('ascii')}"

# ───────────────── プロンプト構築 ───────────────── #

def build_user_content(
    grid_data_url: str,
) -> List[Dict]:
    prompt = """\
## Non-contrast Head CT — ICH Outcome Prediction

The attached image is a **5×5 grid** of non-contrast head CT slices. \
Each cell is labeled with its slice number (top-left label). \
Slices are arranged in ascending slice-number order (left-to-right, top-to-bottom). \
Not all 25 cells may contain a slice — empty (black) cells should be ignored.

**Slice thickness: 5 mm.**  \
For ABC/2 calculation, count hematoma-containing slices for C \
(for each slice assign a weight based on hematoma size relative to the largest slice: \
<25% = 0 (exclude), 25–75% = 0.5 slice, >75% = 1 slice; \
C = (sum of slice weights) × 5 mm).

---

### Step 1 — CT Findings
Systematically describe:
- **Hematoma location**: lobe/region (e.g., right basal ganglia, left thalamus, lobar, \
cerebellar, brainstem) and any intraventricular (IVH) or subarachnoid extension.
- **Hematoma volume (ABC/2)**: identify the slice with the largest hematoma, \
measure A (longest diameter, mm) and B (perpendicular diameter, mm) on that slice, \
count hematoma-containing slices for C, compute A × B × C / 2 (mL). Show working.
- **Mass effect**: midline shift (mm if visible), sulcal effacement, herniation signs.
- **Other**: perilesional edema, hydrocephalus, prior infarcts, incidental findings.

---
"""
    return [
        {"type": "input_text", "text": prompt},
        {"type": "input_image", "image_url": grid_data_url},
    ]

# ───────────────── レスポンス処理 ───────────────── #

def _extract_text_from_response(resp) -> str:
    text = getattr(resp, "output_text", None)
    if text:
        return text.strip()
    try:
        parts = []
        for item in getattr(resp, "output", []) or []:
            for c in getattr(item, "content", []) or []:
                if getattr(c, "type", "") in ("output_text", "text"):
                    t = getattr(c, "text", "")
                    if t:
                        parts.append(t)
        text = "".join(parts).strip()
        if text:
            return text
    except Exception:
        pass
    return ""

def _extract_model_from_response(resp) -> str:
    for attr in ("model", "deployment", "deployment_id", "model_id"):
        v = getattr(resp, attr, None)
        if v:
            return str(v)
    try:
        v = resp.get("model")  # type: ignore[attr-defined]
        if v:
            return str(v)
    except Exception:
        pass
    return str(deployment)

def parse_probabilities(text: str) -> Dict[str, Optional[float]]:
    """
    GPT出力の [PROBABILITIES] ブロック内のJSONから確率値を抽出する。
    パース失敗時は None を返す。
    """
    result: Dict[str, Optional[float]] = {
        "prob_mrs_ge3": None,
        "prob_mrs_ge4": None,
        "prob_mrs_ge5": None,
        "prob_mrs_eq6": None,
    }
    block = re.search(r"\[PROBABILITIES\](.*?)\[/PROBABILITIES\]", text, re.DOTALL)
    if not block:
        return result
    # コードフェンス(```json ... ```)があれば除去してJSONだけ取り出す
    body = re.sub(r"```(?:json)?", "", block.group(1)).replace("```", "").strip()
    try:
        data = json.loads(body)
        mapping = {
            "prob_mrs_ge3": "mRS_ge3",
            "prob_mrs_ge4": "mRS_ge4",
            "prob_mrs_ge5": "mRS_ge5",
            "prob_mrs_eq6": "mRS_eq6",
        }
        for key, json_key in mapping.items():
            if json_key in data:
                result[key] = round(float(data[json_key]), 4)
    except (json.JSONDecodeError, ValueError):
        pass
    return result

def parse_ct_findings(text: str) -> str:
    block = re.search(r"\[CT_FINDINGS\](.*?)\[/CT_FINDINGS\]", text, re.DOTALL)
    return block.group(1).strip() if block else ""

def parse_predicted_mrs(text: str) -> Optional[int]:
    """[PREDICTED_MRS]タグから退院時mRS推定値（0–6の整数）を抽出する。"""
    block = re.search(r"\[PREDICTED_MRS\](.*?)\[/PREDICTED_MRS\]", text, re.DOTALL)
    if not block:
        return None
    try:
        val = int(block.group(1).strip())
        if 0 <= val <= 6:
            return val
    except ValueError:
        pass
    return None

def parse_severity(text: str) -> str:
    block = re.search(r"\[SEVERITY\](.*?)\[/SEVERITY\]", text, re.DOTALL)
    return block.group(1).strip() if block else ""

def parse_reasoning(text: str) -> str:
    block = re.search(r"\[REASONING\](.*?)\[/REASONING\]", text, re.DOTALL)
    return block.group(1).strip() if block else ""

def responses_once(user_content: List[Dict]) -> Tuple[str, Optional[str], str]:
    system_instructions = """\
You are a stroke neurologist specializing in intracerebral hemorrhage (ICH).
The CT image is a 5×5 grid of labeled slices — use the slice numbers to reference specific slices.

### Step 2a — CT Risk Integration

List every CT finding that meaningfully shifts prognosis, \
stating its direction (↑ worse / ↓ better):
- Volume (mL), location (supratentorial deep / lobar / infratentorial / brainstem), \
IVH presence, herniation signs, midline shift, perilesional edema

Then summarise whether the combined CT profile is **low / moderate / high / very high** risk \
relative to this institution's ICH cohort.

---

### Step 2b — Overall Severity Judgment

Based on everything identified in Steps 1 and 2a, make an integrated clinical judgment \
of this patient's overall severity. Reason holistically:

- Which CT factors dominate prognosis in this specific patient?
- Are there synergistic combinations (e.g., large volume + IVH, brainstem location + herniation) \
  that compound risk beyond what any single finding would suggest?
- Are there any mitigating factors?
- Assign an overall severity category: **low / moderate / high / very high**, \
  with a one-sentence justification.

---

### Step 2c-i — Unconstrained Raw Estimate

Based **solely** on the CT findings for this individual patient — \
without reference to any population statistics — form your raw clinical judgment \
of how this patient compares to a **typical** ICH patient. \
Internally note whether this patient is below average, average, or above average risk \
for each outcome. Do **not** output these raw judgments yet.

---

### Step 2c-ii — Base-Rate Anchored Calibration

The table below lists this institution's empirical outcome prevalences, \
derived from clinical records independent of any AI prediction.

| Outcome | Institutional prevalence |
|---------|--------------------------|
| mRS ≥ 3 at discharge        | **79.4 %** |
| mRS ≥ 4 at discharge        | **65.7 %** |
| mRS ≥ 5 at discharge        | **30.3 %** |
| mRS = 6 (worst discharge outcome) | **13.7 %** |

These prevalences are the **sole calibration reference**. Use them as follows:

- A patient judged **average risk** in Step 2c-i → output equals the prevalence above.
- A patient judged **below average** → output is proportionally lower than the prevalence.
- A patient judged **above average** → output is proportionally higher than the prevalence.
- The degree of deviation should reflect how far this patient's CT profile is from \
  the typical ICH patient at this institution.

**Do not anchor your final value directly to the prevalence number. \
The prevalence defines the midpoint of the scale, not a default answer.**

**mRS=6 calibration reference (external validation)**: \
A deep-learning model validated in an independent Japanese ICH cohort (n=175, \
published in JAHA) and confirmed to be well-calibrated produced the following \
predicted probability distributions for in-hospital death (mRS=6):

A well-calibrated model assigned the following mRS=6 probabilities \
for patients who actually died in hospital (n=24): \
median 0.80, IQR 0.66–0.88, range 0.08–0.91. \
If you judge this patient likely to die, your mRS=6 probability should be \
substantially above the base rate (0.137), typically in the range 0.50–0.90. \
Do not default to values near the base rate for high or very-high-risk patients.

**Hard constraints:**
- Logical ordering must hold: P(mRS≥3) ≥ P(mRS≥4) ≥ P(mRS≥5) ≥ P(mRS=6).
- Each value must be between 0.00 and 1.00 (two decimal places).

---

### Required Output Format
Return your answer in **exactly** the following format (no extra text between the tags):

[CT_FINDINGS]
<hematoma location, ABC/2 volume with working, mass effect, IVH>
[/CT_FINDINGS]

[SEVERITY]
<overall severity category (low/moderate/high/very high) and one-sentence justification>
[/SEVERITY]

[PROBABILITIES]
```json
{
  "mRS_ge3": <0.00-1.00>,
  "mRS_ge4": <0.00-1.00>,
  "mRS_ge5": <0.00-1.00>,
  "mRS_eq6": <0.00-1.00>
}
```
[/PROBABILITIES]

[PREDICTED_MRS]
<single integer 0–6: your best estimate of discharge mRS based on the CT findings and the probabilities above. Output the integer only, no other text.>
[/PREDICTED_MRS]

[REASONING]
<3–5 sentences: how CT findings determined the severity score, \
what the raw estimates were before calibration, how the base-rate anchoring shifted each value, \
and why the predicted mRS integer is consistent with the final probabilities>
[/REASONING]

Do NOT include chain-of-thought outside the designated tags.\
"""
    for attempt in range(1, MAX_RETRIES + 1):
        try:
            kwargs = dict(
                model=deployment,
                instructions=system_instructions,
                input=[{"role": "user", "content": user_content}],
                text={"verbosity": "low"},
            )
            if STRICT_REASONING:
                kwargs["reasoning"] = {"effort": REASONING_EFFORT}
            resp = client.responses.create(**kwargs)
            text = _extract_text_from_response(resp)
            used_model = _extract_model_from_response(resp)
            return (text if text else FALLBACK_TEXT, None, used_model)
        except RETRY_ERRORS as exc:
            msg = str(exc)
            if "not supported" in msg.lower() or "unknown parameter" in msg.lower():
                return (FALLBACK_TEXT,
                        f"request failed (reasoning/verbosity unsupported): {msg}",
                        str(deployment))
            if attempt == MAX_RETRIES:
                return (FALLBACK_TEXT, f"request failed after retries: {msg}", str(deployment))
            # 429 / no_capacity は長い指数バックオフ
            is_rate_limit = (
                "429" in msg or "no_capacity" in msg.lower()
                or "too_many_requests" in msg.lower() or "rate limit" in msg.lower()
            )
            if is_rate_limit:
                wait = RATE_LIMIT_WAIT_SEC * (2 ** (attempt - 1))  # 60, 120, 240, ...
                print(f"   ⚠️ 429/no_capacity (attempt {attempt}/{MAX_RETRIES}): "
                      f"{wait}秒待機してリトライします…", file=sys.stderr)
            else:
                wait = WAIT_SEC * attempt
            time.sleep(wait)
        except Exception as exc:
            return (FALLBACK_TEXT, f"unexpected error: {exc}", str(deployment))

# ───────────────── 確率リトライ付きAPI呼び出し ───────────────── #

def responses_until_probs(user_content: List[Dict]) -> Tuple[str, Optional[str], str]:
    """
    予測確率（4値すべて）が取得できるまで PROB_MAX_RETRIES 回リトライする。
    """
    for prob_attempt in range(1, PROB_MAX_RETRIES + 1):
        ans, err, used_model = responses_once(user_content)
        probs = parse_probabilities(ans)
        if all(v is not None for v in probs.values()):
            return ans, err, used_model
        if err and ("request failed" in err or "unexpected error" in err):
            # API自体がエラーの場合はそのまま返す（responses_once 内でリトライ済み）
            return ans, err, used_model
        print(f"   ⚠️ 予測確率が取得できませんでした (prob_attempt {prob_attempt}/{PROB_MAX_RETRIES})、リトライします…",
              file=sys.stderr)
        time.sleep(WAIT_SEC)
    print(f"   ❌ 予測確率を {PROB_MAX_RETRIES} 回試みましたが取得できませんでした。", file=sys.stderr)
    return ans, err, used_model  # type: ignore[return-value]

# ───────────────── 保存 ───────────────── #

def save_results(results: List[Dict], xlsx_path: Path, csv_path: Path) -> None:
    if not results:
        print("⚠️ 保存対象が空のためスキップ", file=sys.stderr)
        return
    df = pd.DataFrame(results)
    with pd.ExcelWriter(xlsx_path, engine="xlsxwriter") as w:
        df.to_excel(w, index=False, sheet_name="results")
    print(f"✅ Results saved (xlsx): {xlsx_path}")
    df.to_csv(csv_path, index=False, encoding="utf-8-sig", quoting=csv.QUOTE_ALL)
    print(f"✅ Results saved (csv):  {csv_path}")

# ─────────────────── メイン ─────────────────── #

def main() -> None:
    output_xlsx = DESKTOP_DIR / OUTPUT_FILE_NAME
    output_csv  = DESKTOP_DIR / OUTPUT_CSV_NAME

    patient_ids = list_patient_ids_from_dir()
    print(f"🤖 Model (Azure deployment): {deployment}")
    print(f"🌐 Endpoint: {endpoint}")
    print(f"🖼  Image source: {SLICES_BASE_DIR}")
    print(f"👥 Patients found: {len(patient_ids)}")

    results: List[Dict] = []
    try:
        for i, id7 in enumerate(patient_ids, 1):
            grid_bytes = build_grid_image(id7)

            if grid_bytes is None:
                print(f"⚠️  [{i}/{len(patient_ids)}] {id7}: 画像なし → スキップ", file=sys.stderr)
                results.append({
                    "id": id7, "run": 1,
                    "ct_findings": "", "severity": "", "reasoning": "",
                    "prob_mrs_ge3": None, "prob_mrs_ge4": None,
                    "prob_mrs_ge5": None, "prob_mrs_eq6": None,
                    "predicted_mrs": None,
                    "raw_response": "SKIPPED (no slice images found)",
                    "model_used": str(deployment),
                    "reasoning_effort": REASONING_EFFORT, "error": ""
                })
                continue

            grid_url     = grid_to_data_url(grid_bytes)
            user_content = build_user_content(grid_url)

            for run in range(1, RUN_COUNT + 1):
                print(f"[{i}/{len(patient_ids)}] querying… id={id7}  run={run}/{RUN_COUNT}")

                ans, err, used_model = responses_until_probs(user_content)
                print(f"   ↳ model: {used_model}")

                probs         = parse_probabilities(ans)
                ct_findings   = parse_ct_findings(ans)
                severity      = parse_severity(ans)
                predicted_mrs = parse_predicted_mrs(ans)
                reasoning     = parse_reasoning(ans)

                results.append({
                    "id":             id7,
                    "run":            run,
                    "ct_findings":    ct_findings,
                    "severity":       severity,
                    "prob_mrs_ge3":   probs["prob_mrs_ge3"],
                    "prob_mrs_ge4":   probs["prob_mrs_ge4"],
                    "prob_mrs_ge5":   probs["prob_mrs_ge5"],
                    "prob_mrs_eq6":   probs["prob_mrs_eq6"],
                    "predicted_mrs":  predicted_mrs,
                    "reasoning":      reasoning,
                    "raw_response":   ans,
                    "model_used":     used_model,
                    "reasoning_effort": REASONING_EFFORT,
                    "error":          err or ""
                })
    finally:
        print(f"💾 Saving → {output_xlsx}, {output_csv}")
        save_results(results, output_xlsx, output_csv)

    print("🎉 All done!")

if __name__ == "__main__":
    main()
